# Copy to .env in this directory. Loaded from dist/loadEnv.js → ../../.env relative to api root.

# --- Neon Postgres (user data: accounts, transactions, trips, budgets, Teller tokens) ---
# When set, the API runs migrations on startup and requires Authorization: Bearer on /api/teller/*.
# Example: postgresql://user:pass@host/neondb?sslmode=require
DATABASE_URL=
# First connection after Neon compute sleeps can take 10–30s; increase if migrations time out.
# DATABASE_CONNECT_TIMEOUT_MS=60000
# Set to false only for local Postgres without SSL.
# DATABASE_SSL=false

# --- Server (Google OAuth, PIN, WebAuthn) ---
PORT=4000
NODE_ENV=development

# Google OAuth — use a dedicated redirect URI for this app in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# CORS: comma-separated browser origins. FRONTEND_URL is merged in (e.g. Vercel production URL).
FRONTEND_ORIGIN=http://localhost:5174,http://localhost:5173,http://127.0.0.1:5174
FRONTEND_URL=http://localhost:5174

# Session signing (32+ random bytes in production).
SESSION_SECRET=change-me-to-a-long-random-string

# Encrypted session + PIN data directory (relative to process.cwd() when the API starts).
DATA_DIR=data

# Optional: PIN / passkey unlock window (ms). Default 12 hours (absolute ceiling).
# PIN_UNLOCK_MS=43200000
# Re-prompt after this many ms of no authenticated API activity while unlocked. Default 15 min. Set 0 to disable.
# PIN_INACTIVITY_TIMEOUT_MS=900000

# If Google omits refresh_token on re-login, set once:
# GOOGLE_OAUTH_PROMPT=consent

# Cross-site SPA + API (e.g. Vercel + Render): set FRONTEND_ORIGIN to your Vercel URL and:
# COOKIE_SAMESITE=none

# WebAuthn — rpID = registrable domain (no port). Origins must match the browser URL exactly.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Budget Tracker
WEBAUTHN_ORIGIN=http://localhost:5174,http://localhost:5173,http://127.0.0.1:5174,http://127.0.0.1:5173
# CHALLENGE_EXPIRATION_MS=300000

# --- Teller (bank link; spawned teller.cjs child process) ---
# Environment: sandbox | development | production
TELLER_ENV=development
# Same id as VITE_TELLER_APP_ID in the frontend.
TELLER_APP_ID=
# Required when TELLER_ENV is development or production (paths to mTLS certs from Teller).
TELLER_CERT_PATH=./certs/certificate.pem
TELLER_KEY_PATH=./certs/private_key.pem
# Local proxy port (must match teller.cjs default unless changed).
TELLER_PROXY_PORT=3001
TELLER_PROXY_HOST=127.0.0.1
# Optional: absolute path to teller.cjs if not next to compiled tellerClient (default: dist/teller/lib/teller.cjs).
# TELLER_JS_PATH=

# Optional: static enrollment token for debugging (prefer POST /api/teller/auth/token from the app).
# TELLER_ACCESS_TOKEN=
