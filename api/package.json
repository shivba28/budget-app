{
  "name": "budget-app-api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/teller/lib dist/teller/static && cp src/teller/lib/teller.cjs dist/teller/lib/ && cp -r src/teller/static dist/teller/",
    "start": "node index.js",
    "dev": "nodemon --watch src --ext ts --exec tsx src/index.ts"
  },
  "dependencies": {
    "@simplewebauthn/server": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.6",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "google-auth-library": "^9.14.1",
    "googleapis": "^144.0.0",
    "http-proxy-middleware": "^3.0.5",
    "pg": "^8.20.0",
    "typescript": "~5.9.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "tsx": "^4.19.2"
  }
}
