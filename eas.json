{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": { "OP_SQLITE_USE_SQLCIPHER": "1" }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.2",
        "resourceClass": "m-medium",
        "simulator": false
      },
      "env": { "OP_SQLITE_USE_SQLCIPHER": "1" }
    },
    "production": {
      "distribution": "store",
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.2",
        "resourceClass": "m-medium",
        "simulator": false
      },
      "android": { "buildType": "app-bundle" },
      "env": { "OP_SQLITE_USE_SQLCIPHER": "1" }
    }
  }
}
