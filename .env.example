# Optional: add EXPO_PUBLIC_* keys here if you add cloud features later.
# Local auth (PIN + device biometrics) does not require environment variables.
#
# Teller (Phase 4): bank linking via hosted Connect (same app id as VITE_TELLER_APP_ID in budget-app).
# EXPO_PUBLIC_TELLER_APP_ID=app_xxxxxxxx
# Optional alias (matches web): EXPO_PUBLIC_TELLER_APPLICATION_ID=
# EXPO_PUBLIC_TELLER_ENV=sandbox
# Hosted Connect URL is always https://connect.teller.io — this value sets the `environment` query param (sandbox | development | production), matching Teller docs / budget-app Settings.
# Sandbox uses standard HTTPS (no mTLS). development/production API access uses mTLS per Teller.
# Optional: override hosted Connect URL (use {{redirect}} for redirect_uri placeholder)
# EXPO_PUBLIC_TELLER_CONNECT_URL=https://...
#
# Restart Metro after changes: npx expo start -c
