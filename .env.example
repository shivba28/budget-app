# Copy to .env and fill in. Never commit .env.

# Unified API. For `npm run dev` (Vite on :5174 with /api proxy), leave unset so auth + /api/user
# use the same origin as the page (session cookie matches). Set only if the app and OAuth callback
# both use a dedicated API origin (e.g. production or API-only localhost:4000).
# VITE_API_URL=http://localhost:4000

# Teller Connect (browser) — same as TELLER_APP_ID on the API
VITE_TELLER_APP_ID=

# Optional: Vite dev proxy target when using relative /api paths (default http://localhost:4000)
# VITE_API_PROXY_TARGET=http://localhost:4000

# @deprecated — use VITE_API_URL
# VITE_BACKEND_URL=
# VITE_SYNC_API_URL=
