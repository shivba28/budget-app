# Copy to .env and fill in. Never commit .env.

# --- Local dev without Neon (recommended together) ---
# 1) Repo root: VITE_USE_LOCAL_STORAGE=true (browser holds app data).
# 2) api/.env: leave DATABASE_URL empty so the API does not connect to Postgres (no ETIMEDOUT).
#    You can still run the API on :4000 for Google sign-in / PIN; /api/user/* returns 503, which is
#    fine because the app uses localStorage for data in this mode.

# When true, the app uses a localStorage-backed adapter for all /api/user data (trips, transactions,
# budgets, categories, overrides) so you can work offline without a backend. Production builds set
# this to false via .env.production.
# VITE_USE_LOCAL_STORAGE=true

# Unified API. For `npm run dev` (Vite on :5174 with /api proxy), leave unset so auth + /api/user
# use the same origin as the page (session cookie matches). Set only if the app and OAuth callback
# both use a dedicated API origin (e.g. production or API-only localhost:4000).
# VITE_API_URL=http://localhost:4000

# Teller Connect (browser) — same as TELLER_APP_ID on the API
VITE_TELLER_APP_ID=

# Optional: Vite dev proxy target when using relative /api paths (default http://localhost:4000)
# VITE_API_PROXY_TARGET=http://localhost:4000

# @deprecated — use VITE_API_URL
# VITE_BACKEND_URL=
# VITE_SYNC_API_URL=

# Optional: client-side lock screen after N ms of no input (default 900000 = 15 min).
# Set to 0 to disable the client-side timer (server-side inactivity lock may still apply).
# VITE_PIN_INACTIVITY_TIMEOUT_MS=900000
